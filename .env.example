MICRONAUT_ENVIRONMENTS=dev,postgres
APP_VERSION=0.1.0-SNAPSHOT
APP_DESCRIPTION=Micronaut starter for document sealing and signing services
DB_HOST=localhost
DB_PORT=5432
DB_NAME=starter
DB_USER=starter
DB_PASSWORD=starter
DB_POOL_MAX_SIZE=10
STORAGE_S3_ENABLED=true
STORAGE_S3_ENDPOINT=http://localhost:9000
STORAGE_S3_REGION=eu-central-1
STORAGE_S3_BUCKET=starter-documents
STORAGE_S3_PATH_STYLE_ACCESS=true
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=minioadmin
PDFBOX_ENABLED=true
DSS_ENABLED=true
FILE_LOGGING_ENABLED=false
JSON_CONSOLE_LOGGING_ENABLED=false
LOG_DIR=logs
LOG_LEVEL=INFO
LOG_MAX_HISTORY=12
LOG_TOTAL_SIZE_CAP=1GB
LOG_MAX_FILE_SIZE=50MB
